{
  "info": {
    "name": "User API Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login API",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"1234\"\n}"
        },
        "url": {
          "raw": "http://localhost:4000/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "4000",
          "path": ["login"]
        }
      }
    },
    {
      "name": "Get Users",
      "request": {
        "method": "GET",
        "url": "http://localhost:4000/users"
      }
    },
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n\"name\":\"Test User\",\n\"email\":\"test@test.com\"\n}"
        },
        "url": "http://localhost:4000/users"
      }
    }
  ]
}